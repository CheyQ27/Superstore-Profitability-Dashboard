    <worksheet name='S/M Budget Overview'>
      <layout-options>
        <caption>
          <formatted-text>
            <run>Average of AD Budget and average of Profit for each S/M.  Color shows details about S/M.  For pane Average of AD Budget:  The marks are labeled by average of AD Budget.  For pane Average of Profit:  The marks are labeled by average of Profit. The view is filtered on S/M, which keeps Indiana/October, Vermont/November and Washington/March.
This summary highlights the top three state/month combinations from the previous analysis, revealing where our customer engagement is strongest. Based on these insights, we should confidently allocate increased advertising spend to these high‑performing segments to maximize ROI in upcoming campaigns.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Orders+ (Superstore)' name='federated.0zqs1ej1dqhmsv1e2ff710w6i10z' />
          </datasources>
          <datasource-dependencies datasource='federated.0zqs1ej1dqhmsv1e2ff710w6i10z'>
            <column caption='S/M' datatype='string' name='[Calculation_1274109862490120]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[State] + &quot;/&quot; + DATENAME(&apos;month&apos;,[Order Date])' />
            </column>
            <column caption='AD Budget' datatype='real' name='[Calculation_1274109862682633]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Profit] * 0.2' />
            </column>
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column-instance column='[Calculation_1274109862682633]' derivation='Avg' name='[avg:Calculation_1274109862682633:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Profit]' derivation='Avg' name='[avg:Profit:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1274109862490120]' derivation='None' name='[none:Calculation_1274109862490120:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0zqs1ej1dqhmsv1e2ff710w6i10z].[none:Calculation_1274109862490120:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:Calculation_1274109862490120:nk]' member='&quot;Indiana/October&quot;' />
              <groupfilter function='member' level='[none:Calculation_1274109862490120:nk]' member='&quot;Vermont/November&quot;' />
              <groupfilter function='member' level='[none:Calculation_1274109862490120:nk]' member='&quot;Washington/March&quot;' />
            </groupfilter>
          </filter>
          <slices>
            <column>[federated.0zqs1ej1dqhmsv1e2ff710w6i10z].[none:Calculation_1274109862490120:nk]</column>
          </slices>
          <aggregation value='true' />
