    <worksheet name='SubCat Profitability'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#ffffff'>SubCat Profitability</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='false' fontcolor='#ffffff' fontsize='10'>Sum of Profit for each Sub-Category.  Color shows sum of Profit.  The marks are labeled by sum of Profit. The data is filtered on Return(Calculated) and TB3. The Return(Calculated) filter keeps 0. The TB3 filter keeps True. </run>
            <run>Æ&#10;</run>
            <run bold='false' fontcolor='#ffffff' fontsize='10'>The superstore should halt the sale of Tables,Bookcases and Supplies and prioritize the sale of Copiers, Phones and Accessories.</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Orders+ (Superstore)' name='federated.0zqs1ej1dqhmsv1e2ff710w6i10z' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='P' datatype='integer' name='[Profit Parameter]' param-domain-type='range' role='measure' type='quantitative' value='3'>
              <calculation class='tableau' formula='3' />
              <range max='10' min='1' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0zqs1ej1dqhmsv1e2ff710w6i10z'>
            <column caption='TB3' datatype='boolean' name='[Calculation_1274109773836293]' role='measure' type='nominal'>
              <calculation class='tableau' formula='RANK(SUM([Profit]), &apos;desc&apos;) &lt;= [Parameters].[Profit Parameter]&#13;&#10;OR&#13;&#10;RANK(SUM([Profit]), &apos;asc&apos;) &lt;= [Parameters].[Profit Parameter]'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column datatype='string' name='[Sub-Category]' role='dimension' type='nominal' />
            <column-instance column='[Sub-Category]' derivation='None' name='[none:Sub-Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Profit]' derivation='Sum' name='[sum:Profit:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1274109773836293]' derivation='User' name='[usr:Calculation_1274109773836293:nk]' pivot='key' type='nominal'>
              <table-calc ordering-type='Rows' />
            </column-instance>
          </datasource-dependencies>
          <computed-sort column='[federated.0zqs1ej1dqhmsv1e2ff710w6i10z].[none:Sub-Category:nk]' direction='DESC' using='[federated.0zqs1ej1dqhmsv1e2ff710w6i10z].[sum:Profit:qk]' />
          <filter class='categorical' column='[federated.0zqs1ej1dqhmsv1e2ff710w6i10z].[usr:Calculation_1274109773836293:nk]'>
            <groupfilter function='member' level='[usr:Calculation_1274109773836293:nk]' member='true' user:ui-domain='relevant' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.0zqs1ej1dqhmsv1e2ff710w6i10z].[usr:Calculation_1274109773836293:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
            <format attr='text-format' field='[federated.0zqs1ej1dqhmsv1e2ff710w6i10z].[sum:Profit:qk]' value='c&quot;$&quot;#,##0,.0K;-&quot;$&quot;#,##0,.0K' />
            <format attr='color' data-class='subtotal' value='#f5f5f5' />
            <format attr='color' data-class='total' value='#c290b4' />
          </style-rule>
          <style-rule element='header'>
            <format attr='background-color' value='#898989' />
          </style-rule>
          <style-rule element='label'>
            <format attr='color' value='#ffffff' />
          </style-rule>
          <style-rule element='pane'>
            <format attr='background-color' value='#898989' />
          </style-rule>
          <style-rule element='table'>
            <format attr='background-color' value='#898989' />
          </style-rule>
          <style-rule element='worksheet'>
            <format attr='font-weight' value='bold' />
            <format attr='color' value='#000000' />
          </style-rule>
          <style-rule element='caption'>
            <format attr='background-color' value='#898989' />
          </style-rule>
          <style-rule element='title'>
            <format attr='background-color' value='#00000000' />
          </style-rule>
        </style>
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
